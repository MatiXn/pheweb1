# Client-side (VITE_* prefix required — bundled into browser code)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-key-here

# Server-only — NEVER prefix with VITE_ (used only in Supabase Edge Functions)
# SUPABASE_SERVICE_ROLE_KEY - SERVER-SIDE ONLY. NEVER expose to frontend/client.
# Used for: Edge Functions, migration scripts, admin operations only.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
RESEND_API_KEY=re_...
